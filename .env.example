# Postgres — svc-productos
PRODUCTOS_DB_NAME=productos_db
PRODUCTOS_DB_USER=productos_user
PRODUCTOS_DB_PASS=productos_pass

# Postgres — svc-ordenes
ORDENES_DB_NAME=ordenes_db
ORDENES_DB_USER=ordenes_user
ORDENES_DB_PASS=ordenes_pass

# Postgres — svc-stock
STOCK_DB_NAME=stock_db
STOCK_DB_USER=stock_user
STOCK_DB_PASS=stock_pass

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Logging
LOG_LEVEL=info

# svc-stock: umbral de stock bajo para generar alertas (default: 10)
STOCK_ALERTA_UMBRAL=10
